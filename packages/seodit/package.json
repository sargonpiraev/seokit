{
  "name": "@sargonpiraev/seodit",
  "description": "Playwright-native SEO assertions for Next.js apps",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sargonpiraev/shared.git",
    "directory": "packages/seodit"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./html": {
      "types": "./dist/html/index.d.ts",
      "default": "./dist/html/index.js"
    },
    "./jsonld": {
      "types": "./dist/jsonld/index.d.ts",
      "default": "./dist/jsonld/index.js"
    },
    "./playwright": {
      "types": "./dist/playwright/index.d.ts",
      "default": "./dist/playwright/index.js"
    }
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsx scripts/readme-gen.ts && tsc",
    "check-types": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "readme:gen": "tsx scripts/readme-gen.ts",
    "release:dry-run": "semantic-release --dry-run"
  },
  "dependencies": {
    "cheerio": "^1.2.0"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.51.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@repo/typescript-config": "*",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.2"
  }
}
