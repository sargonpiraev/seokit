{
  "name": "seodit-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "generate:matcher-docs": "node --import tsx scripts/generate-matcher-docs.mts",
    "dev": "npm run generate:matcher-docs && node ../../scripts/dev-next.mjs 4002",
    "build": "npm run generate:matcher-docs && fumadocs-mdx && next build",
    "start": "next start --port 4002",
    "check-types": "npm run generate:matcher-docs && fumadocs-mdx && next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@sargonpiraev/seodit": "*",
    "fumadocs-core": "^16.10.5",
    "fumadocs-mdx": "^15.0.12",
    "fumadocs-typescript": "^5.2.6",
    "fumadocs-ui": "^16.10.5",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.7",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.13.11",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "tailwindcss": "^4.1.7",
    "tsx": "^4.21.0",
    "typescript": "5.9.2"
  }
}
